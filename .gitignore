# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code
.claude/

# Jekyll
_site/
.jekyll-cache/
.jekyll-metadata
Gemfile.lock

# Draft blog posts — not part of the project docs
docs/medium.md

# Demo assets: only commit the storyboard stills referenced in README.
# Everything else (raw mp4 source, earlier takes, scratch frames) stays local.
demo-assets/*
!demo-assets/storyboard-*.png

# Node
node_modules/

# Scaffolded apps — generated output, not source
apps/*
!apps/.gitkeep

# examples/<slug>/fonts/ is copied verbatim from pwa/fonts/ at scaffold
# time. Keeping the copied bytes out of git means the scaffold-drift
# check only polices the files the scaffolder actually generates
# (index.html, manifest.json, icon.svg, sw.js) — font drift is already
# covered by pwa/fonts/ being committed.
examples/*/fonts/

# Logs
*.log
